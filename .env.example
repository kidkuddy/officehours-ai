# --- Postgres ---
POSTGRES_USER=officehours
POSTGRES_PASSWORD=officehours
POSTGRES_DB=officehours

# --- API ---
# Connection string the api/ohctl use to reach Postgres.
# Inside docker-compose the host is the `db` service; locally use localhost.
DATABASE_URL=postgres://officehours:officehours@db:5432/officehours?sslmode=disable

# Secret used to sign JWTs.
JWT_SECRET=change-me-in-production

# Optional fallback. If set, the claude CLI uses this instead of the mounted subscription creds.
ANTHROPIC_API_KEY=

# Filesystem locations (defaults match the docker-compose mounts).
UPLOAD_DIR=/data/uploads
SEED_DIR=/seed
CONFIG_DIR=/config

# --- Agent backend ---
# Which CLI the job worker execs for agent turns: 'claude' (default) | 'gemini'.
AGENT_PROVIDER=claude

# --- Gemini (Vertex AI) ---
# Only used when AGENT_PROVIDER=gemini. Auth uses Google ADC: run
#   gcloud auth application-default login
# on the host first (compose mounts ${HOME}/.config/gcloud into the container).
GOOGLE_CLOUD_PROJECT=pryde-492609
GOOGLE_CLOUD_LOCATION=global
GOOGLE_GENAI_USE_VERTEXAI=true

# --- Ports (host side) ---
# api  -> 8080
# web  -> 3000
# db   -> 5432
